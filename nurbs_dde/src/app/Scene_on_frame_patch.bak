// ── on_frame ──────────────────────────────────────────────────────────────────

void Scene::on_frame() {
    sync_viewport();
    update_camera();
    update_hover();

    // Update coord debug AFTER hover so it captures the complete snap state
    m_coord_debug.update(m_vp, m_hover, m_conics, m_api.viewport_size());

    draw_main_panel();
    m_analysis_panel.draw(m_hover, m_api.math_font_body());
    m_coord_debug.draw();   // dedicated floating window

    submit_grid();
    submit_axes();
    submit_conics();
    submit_epsilon_ball();
    submit_interval_lines();
    submit_secant_line();
    submit_tangent_line();
}
